@page "/transactions/new"
@page "/transactions/{Id:guid}/edit"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using FinanceTracker.Domain.Enums
@inject ITransactionService TransactionService
@inject ICategoryService CategoryService
@inject IAccountService AccountService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Edit Transaction" : "New Transaction") – Finance Tracker</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-3 pa-0" />

<MudPaper Class="pa-6" Elevation="2" Style="max-width:680px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Edit Transaction" : "New Transaction")</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate />
    }
    else
    {
        <MudForm @ref="_form" Model="_model">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Date" @bind-Date="_dateValue" Required
                                   DateFormat="dd.MM.yyyy" Editable />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="TransactionType" Label="Transaction Type" @bind-Value="_model.TransactionType" Required>
                        @foreach (TransactionType t in Enum.GetValues(typeof(TransactionType)))
                        {
                            <MudSelectItem Value="t">@t</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Description" @bind-Value="_model.Description"
                                  Required MaxLength="500" Counter="500" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" Label="Amount (EUR)" @bind-Value="_model.Amount"
                                     Required Format="F2"
                                     HelperText="Use negative for expenses, positive for income" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid?" Label="Category" @bind-Value="_model.CategoryId" Clearable
                               AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="Guid?" Value="(Guid?)null">— None —</MudSelectItem>
                        @foreach (var cat in _categories)
                        {
                            <MudSelectItem T="Guid?" Value="(Guid?)cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="Guid" Label="Account" @bind-Value="_model.AccountId" Required
                               AnchorOrigin="Origin.BottomLeft">
                        @foreach (var acc in _accounts)
                        {
                            <MudSelectItem T="Guid" Value="acc.Id">@acc.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudCheckBox T="bool" @bind-Value="_model.IsRecurring" Label="Recurring transaction" />
                </MudItem>
                <MudItem xs="12">
                    <MudTextField Label="Notes" @bind-Value="_model.Notes"
                                  Lines="3" MaxLength="1000" Counter="1000" />
                </MudItem>
            </MudGrid>

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@_errorMessage</MudAlert>
            }

            <MudStack Row Class="mt-5" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SubmitAsync" Disabled="_saving">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                    @(IsEdit ? "Save Changes" : "Create Transaction")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/transactions">Cancel</MudButton>
            </MudStack>
        </MudForm>
    }
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;
    private MudForm _form = default!;

    private IReadOnlyList<CategoryDto> _categories = [];
    private IReadOnlyList<AccountDto> _accounts = [];

    private DateTime? _dateValue = DateTime.Today;

    private TransactionFormModel _model = new();

    private List<BreadcrumbItem> _breadcrumbs = [];

    private readonly CancellationTokenSource _cts = new();
    private bool _disposed;

    protected override bool ShouldRender() => !_disposed;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new("Transactions", "/transactions"),
            new(IsEdit ? "Edit" : "New", null, disabled: true)
        ];

        try
        {
            _categories = await CategoryService.GetAllAsync(_cts.Token);
            _accounts = await AccountService.GetAllAsync(_cts.Token);

            if (IsEdit)
            {
                var tx = await TransactionService.GetByIdAsync(Id!.Value, _cts.Token);
                if (tx is not null)
                {
                    _model = new TransactionFormModel
                    {
                        TransactionType = tx.TransactionType,
                        Amount = tx.Amount,
                        Description = tx.Description,
                        CategoryId = tx.CategoryId,
                        AccountId = tx.AccountId,
                        Notes = tx.Notes,
                        IsRecurring = tx.IsRecurring
                    };
                    _dateValue = tx.Date.ToDateTime(TimeOnly.MinValue);
                }
                else
                {
                    Nav.NavigateTo("/transactions");
                    return;
                }
            }
            else if (_accounts.Count > 0)
            {
                _model.AccountId = _accounts[0].Id;
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { return; }
        finally { if (!_disposed) _loading = false; }
    }

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        _errorMessage = null;

        var date = _dateValue.HasValue
            ? DateOnly.FromDateTime(_dateValue.Value)
            : DateOnly.FromDateTime(DateTime.Today);

        try
        {
            if (IsEdit)
            {
                var result = await TransactionService.UpdateAsync(new UpdateTransactionCommand(
                    Id!.Value, date, _model.TransactionType, _model.Amount,
                    _model.Description, _model.AccountId, _model.CategoryId,
                    _model.Notes, _model.IsRecurring), _cts.Token);

                if (result.Succeeded)
                {
                    Snackbar.Add("Transaction updated.", Severity.Success);
                    Nav.NavigateTo("/transactions");
                }
                else
                {
                    _errorMessage = string.Join(", ", result.Errors);
                    _saving = false;
                }
            }
            else
            {
                await TransactionService.CreateAsync(new CreateTransactionCommand(
                    date, _model.TransactionType, _model.Amount,
                    _model.Description, _model.AccountId, _model.CategoryId,
                    _model.Notes, _model.IsRecurring), _cts.Token);

                Snackbar.Add("Transaction created.", Severity.Success);
                Nav.NavigateTo("/transactions");
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { _saving = false; }
    }

    public void Dispose()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
    }

    private class TransactionFormModel
    {
        public TransactionType TransactionType { get; set; } = TransactionType.Other;
        public decimal Amount { get; set; }
        public string Description { get; set; } = string.Empty;
        public Guid? CategoryId { get; set; }
        public Guid AccountId { get; set; }
        public string? Notes { get; set; }
        public bool IsRecurring { get; set; }
    }
}

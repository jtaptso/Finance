@page "/budgets/new"
@page "/budgets/{Id:guid}/edit"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using FinanceTracker.Domain.Enums
@inject IBudgetService BudgetService
@inject ICategoryService CategoryService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Edit Budget" : "New Budget") – Finance Tracker</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-3 pa-0" />

<MudPaper Class="pa-6" Elevation="2" Style="max-width:560px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Edit Budget" : "New Budget")</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate />
    }
    else
    {
        <MudForm @ref="_form" Model="_model">
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudSelect T="Guid" Label="Category" @bind-Value="_model.CategoryId" Required
                               AnchorOrigin="Origin.BottomLeft" Disabled="IsEdit">
                        @foreach (var cat in _categories.Where(c => c.Type == CategoryType.Expense))
                        {
                            <MudSelectItem T="Guid" Value="cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudNumericField T="decimal" Label="Budget Amount (EUR)" @bind-Value="_model.Amount"
                                     Required Format="F2" Min="0.01m" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="BudgetPeriod" Label="Period" @bind-Value="_model.Period" Required>
                        <MudSelectItem Value="BudgetPeriod.Monthly">Monthly</MudSelectItem>
                        <MudSelectItem Value="BudgetPeriod.Yearly">Yearly</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="Start Date" @bind-Date="_startDateValue" Required DateFormat="dd.MM.yyyy" Editable />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudDatePicker Label="End Date (optional)" @bind-Date="_endDateValue" Clearable DateFormat="dd.MM.yyyy" Editable />
                </MudItem>
            </MudGrid>

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@_errorMessage</MudAlert>
            }

            <MudStack Row Class="mt-5" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SubmitAsync" Disabled="_saving">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                    @(IsEdit ? "Save Changes" : "Create Budget")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/budgets">Cancel</MudButton>
            </MudStack>
        </MudForm>
    }
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;
    private MudForm _form = default!;

    private IReadOnlyList<CategoryDto> _categories = [];
    private List<BreadcrumbItem> _breadcrumbs = [];

    private DateTime? _startDateValue = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private DateTime? _endDateValue;

    private BudgetFormModel _model = new();

    private readonly CancellationTokenSource _cts = new();
    private bool _disposed;

    protected override bool ShouldRender() => !_disposed;

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new("Budgets", "/budgets"),
            new(IsEdit ? "Edit" : "New", null, disabled: true)
        ];

        try
        {
            _categories = await CategoryService.GetAllAsync(_cts.Token);

            if (IsEdit)
            {
                var budget = await BudgetService.GetByIdAsync(Id!.Value, _cts.Token);
                if (budget is not null)
                {
                    _model = new BudgetFormModel
                    {
                        CategoryId = budget.CategoryId,
                        Amount = budget.Amount,
                        Period = budget.Period
                    };
                    _startDateValue = budget.StartDate.ToDateTime(TimeOnly.MinValue);
                    _endDateValue = budget.EndDate?.ToDateTime(TimeOnly.MinValue);
                }
                else
                {
                    Nav.NavigateTo("/budgets");
                    return;
                }
            }
            else if (_categories.Count > 0)
            {
                _model.CategoryId = _categories.FirstOrDefault(c => c.Type == CategoryType.Expense)?.Id ?? Guid.Empty;
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { return; }
        finally { if (!_disposed) _loading = false; }
    }

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        _errorMessage = null;

        var startDate = _startDateValue.HasValue
            ? DateOnly.FromDateTime(_startDateValue.Value)
            : DateOnly.FromDateTime(DateTime.Today);
        var endDate = _endDateValue.HasValue
            ? DateOnly.FromDateTime(_endDateValue.Value)
            : (DateOnly?)null;

        try
        {
            if (IsEdit)
            {
                var result = await BudgetService.UpdateAsync(new UpdateBudgetCommand(
                    Id!.Value, _model.Amount, _model.Period, startDate, endDate), _cts.Token);

                if (result.Succeeded)
                {
                    Snackbar.Add("Budget updated.", Severity.Success);
                    Nav.NavigateTo("/budgets");
                }
                else
                {
                    _errorMessage = string.Join(", ", result.Errors);
                    _saving = false;
                }
            }
            else
            {
                await BudgetService.CreateAsync(new CreateBudgetCommand(
                    _model.CategoryId, _model.Amount, _model.Period, startDate, endDate), _cts.Token);

                Snackbar.Add("Budget created.", Severity.Success);
                Nav.NavigateTo("/budgets");
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { _saving = false; }
    }

    public void Dispose()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
    }

    private class BudgetFormModel
    {
        public Guid CategoryId { get; set; }
        public decimal Amount { get; set; } = 100m;
        public BudgetPeriod Period { get; set; } = BudgetPeriod.Monthly;
    }
}

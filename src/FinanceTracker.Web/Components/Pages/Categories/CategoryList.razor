@page "/categories"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@implements IDisposable
@using FinanceTracker.Application.Categories.DTOs
@inject ICategoryService CategoryService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Categories – Finance Tracker</PageTitle>

<MudGrid AlignItems="Center" Class="mb-3">
    <MudItem xs="6"><MudText Typo="Typo.h5">Categories</MudText></MudItem>
    <MudItem xs="6" Style="text-align:right">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   Href="/categories/new">Add Category</MudButton>
    </MudItem>
</MudGrid>

<MudPaper Elevation="2">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate Color="Color.Primary" />
    }
    <MudTable Items="_categories" Dense Hover Striped>
        <HeaderContent>
            <MudTh>Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Keywords</MudTh>
            <MudTh>Default</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @if (context.Color is not null)
                {
                    <MudChip T="string" Size="Size.Small" Style="@($"background:{context.Color};color:#fff")">
                        @context.Name
                    </MudChip>
                }
                else
                {
                    <span>@context.Name</span>
                }
            </MudTd>
            <MudTd>@context.Type</MudTd>
            <MudTd>
                <MudText Typo="Typo.caption">@string.Join(", ", context.Keywords.Take(5))</MudText>
            </MudTd>
            <MudTd>@(context.IsDefault ? "✓" : "")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               Href="@($"/categories/{context.Id}/edit")" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               Disabled="context.IsDefault"
                               OnClick="@(() => DeleteAsync(context))" />
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <MudText Color="Color.Secondary" Class="pa-4">No categories found.</MudText>
        </NoRecordsContent>
    </MudTable>
</MudPaper>

@code {
    private bool _loading = true;
    private IReadOnlyList<CategoryDto> _categories = [];

    private readonly CancellationTokenSource _cts = new();
    private bool _disposed;

    protected override bool ShouldRender() => !_disposed;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _categories = await CategoryService.GetAllAsync(_cts.Token);
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { return; }
        finally { if (!_disposed) _loading = false; }
    }

    private async Task DeleteAsync(CategoryDto cat)
    {
        try
        {
            var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete category '{cat.Name}'?");

            if (confirmed)
            {
                var result = await CategoryService.DeleteAsync(cat.Id, _cts.Token);
                if (result.Succeeded)
                {
                    Snackbar.Add("Category deleted.", Severity.Success);
                    if (!_disposed) _categories = await CategoryService.GetAllAsync(_cts.Token);
                }
                else
                {
                    Snackbar.Add(string.Join(", ", result.Errors), Severity.Error);
                }
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException or ObjectDisposedException) { }
    }

    public void Dispose()
    {
        _disposed = true;
        _cts.Cancel();
        _cts.Dispose();
    }
}

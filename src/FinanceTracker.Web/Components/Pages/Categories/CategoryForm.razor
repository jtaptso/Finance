@page "/categories/new"
@page "/categories/{Id:guid}/edit"
@rendermode InteractiveServer
@using FinanceTracker.Application.Categories.DTOs
@using FinanceTracker.Application.Categories.Queries.GetAllCategories
@using FinanceTracker.Application.Categories.Queries.GetCategoryById
@using FinanceTracker.Application.Categories.Commands.CreateCategory
@using FinanceTracker.Application.Categories.Commands.UpdateCategory
@using FinanceTracker.Domain.Enums
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Edit Category" : "New Category") – Finance Tracker</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-3 pa-0" />

<MudPaper Class="pa-6" Elevation="2" Style="max-width:680px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Edit Category" : "New Category")</MudText>

    @if (_loading)
    {
        <MudProgressCircular Indeterminate />
    }
    else
    {
        <MudForm @ref="_form" Model="_model">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="8">
                    <MudTextField Label="Name" @bind-Value="_model.Name" Required MaxLength="100" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="CategoryType" Label="Type" @bind-Value="_model.Type" Required>
                        <MudSelectItem Value="CategoryType.Expense">Expense</MudSelectItem>
                        <MudSelectItem Value="CategoryType.Income">Income</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Color (hex or CSS)" @bind-Value="_model.Color"
                                  Placeholder="#e53935" MaxLength="20" />
                    @if (!string.IsNullOrWhiteSpace(_model.Color))
                    {
                        <MudChip T="string" Class="mt-1" Size="Size.Small"
                                 Style="@($"background:{_model.Color};color:#fff")">
                            Preview
                        </MudChip>
                    }
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField Label="Icon (Material icon name)" @bind-Value="_model.Icon"
                                  Placeholder="shopping_cart" MaxLength="50" />
                </MudItem>
                <MudItem xs="12">
                    <MudSelect T="Guid?" Label="Parent Category (optional)" @bind-Value="_model.ParentCategoryId"
                               Clearable AnchorOrigin="Origin.BottomLeft">
                        <MudSelectItem T="Guid?" Value="(Guid?)null">— None (top-level) —</MudSelectItem>
                        @foreach (var cat in _otherCategories)
                        {
                            <MudSelectItem T="Guid?" Value="(Guid?)cat.Id">@cat.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <!-- Keywords -->
                <MudItem xs="12">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">
                        Keywords for auto-categorization
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Inline>
                            — matched against transaction descriptions
                        </MudText>
                    </MudText>
                    <MudStack Row AlignItems="AlignItems.Center" Spacing="2">
                        <MudTextField @bind-Value="_newKeyword" Label="Add keyword"
                                      @onkeydown="HandleKeywordKeyDown" />
                        <MudButton Variant="Variant.Outlined" OnClick="AddKeyword"
                                   Disabled="string.IsNullOrWhiteSpace(_newKeyword)">Add</MudButton>
                    </MudStack>
                    <MudChipSet T="string" Class="mt-2">
                        @foreach (var kw in _model.Keywords)
                        {
                            <MudChip T="string" OnClose="@(() => RemoveKeyword(kw))" Color="Color.Default">
                                @kw
                            </MudChip>
                        }
                    </MudChipSet>
                </MudItem>
            </MudGrid>

            @if (_errorMessage is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mt-3">@_errorMessage</MudAlert>
            }

            <MudStack Row Class="mt-5" Spacing="2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="SubmitAsync" Disabled="_saving">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate Class="mr-2" /> }
                    @(IsEdit ? "Save Changes" : "Create Category")
                </MudButton>
                <MudButton Variant="Variant.Outlined" Href="/categories">Cancel</MudButton>
            </MudStack>
        </MudForm>
    }
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }

    private bool IsEdit => Id.HasValue;
    private bool _loading = true;
    private bool _saving;
    private string? _errorMessage;
    private MudForm _form = default!;
    private string _newKeyword = string.Empty;

    private IReadOnlyList<CategoryDto> _allCategories = [];
    private IEnumerable<CategoryDto> _otherCategories =>
        _allCategories.Where(c => c.Id != Id);

    private List<BreadcrumbItem> _breadcrumbs = [];
    private CategoryFormModel _model = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs =
        [
            new("Categories", "/categories"),
            new(IsEdit ? "Edit" : "New", null, disabled: true)
        ];

        _allCategories = await Mediator.Send(new GetAllCategoriesQuery());

        if (IsEdit)
        {
            var cat = await Mediator.Send(new GetCategoryByIdQuery(Id!.Value));
            if (cat is not null)
            {
                _model = new CategoryFormModel
                {
                    Name = cat.Name,
                    Type = cat.Type,
                    Color = cat.Color,
                    Icon = cat.Icon,
                    ParentCategoryId = cat.ParentCategoryId,
                    Keywords = [.. cat.Keywords]
                };
            }
            else
            {
                Nav.NavigateTo("/categories");
                return;
            }
        }

        _loading = false;
    }

    private void AddKeyword()
    {
        var kw = _newKeyword.Trim();
        if (!string.IsNullOrEmpty(kw) && !_model.Keywords.Contains(kw, StringComparer.OrdinalIgnoreCase))
            _model.Keywords.Add(kw);
        _newKeyword = string.Empty;
    }

    private void RemoveKeyword(string kw) => _model.Keywords.Remove(kw);

    private void HandleKeywordKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddKeyword();
    }

    private async Task SubmitAsync()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _saving = true;
        _errorMessage = null;

        if (IsEdit)
        {
            var result = await Mediator.Send(new UpdateCategoryCommand(
                Id!.Value, _model.Name, _model.Type, _model.Icon, _model.Color,
                _model.ParentCategoryId, _model.Keywords));

            if (result.Succeeded)
            {
                Snackbar.Add("Category updated.", Severity.Success);
                Nav.NavigateTo("/categories");
            }
            else
            {
                _errorMessage = string.Join(", ", result.Errors);
                _saving = false;
            }
        }
        else
        {
            await Mediator.Send(new CreateCategoryCommand(
                _model.Name, _model.Type, _model.Icon, _model.Color,
                _model.ParentCategoryId, _model.Keywords));

            Snackbar.Add("Category created.", Severity.Success);
            Nav.NavigateTo("/categories");
        }
    }

    private class CategoryFormModel
    {
        public string Name { get; set; } = string.Empty;
        public CategoryType Type { get; set; } = CategoryType.Expense;
        public string? Color { get; set; }
        public string? Icon { get; set; }
        public Guid? ParentCategoryId { get; set; }
        public List<string> Keywords { get; set; } = [];
    }
}
